# Anthropic Claude API Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# GitHub Integration
# In dev, the in-memory adapter is used by default. Fake issues are
# visible at http://localhost:4000/dev/github. Set GITHUB_USE_REAL_API=1
# to hit the real REST API instead and use the env vars below.
#
# PAT permissions:
#   - Issues:  Read and write
#   - Metadata: Read
#   - Projects: Read and write (org or user level, for board sync)
#
# GITHUB_USE_REAL_API=1
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-org-or-user
GITHUB_DEFAULT_REPO=your-default-repo

# GitHub Projects v2 (board) sync. Both IDs are GraphQL node IDs.
# Find them with `gh project list --owner <org>` and `gh project field-list <num>`.
GITHUB_PROJECT_ID=PVT_xxx
GITHUB_STATUS_FIELD_ID=PVTSSF_xxx

# Webhook signing secret. Same value must be set in the repo webhook
# settings on GitHub.
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# Override only for GitHub Enterprise
# GITHUB_API_URL=https://api.github.com
# GITHUB_GRAPHQL_URL=https://api.github.com/graphql
