# Anthropic Claude API Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# GitHub Integration
# In dev, the in-memory adapter is used by default. Fake issues are
# visible at http://localhost:4000/dev/github. Set GITHUB_USE_REAL_API=1
# to hit the real REST API instead and use the env vars below.
#
# PAT with `Issues: Read and write` + `Metadata: Read` permissions.
# Issues are created in GITHUB_OWNER/GITHUB_DEFAULT_REPO unless the request
# stores its own override.
# GITHUB_USE_REAL_API=1
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-org-or-user
GITHUB_DEFAULT_REPO=your-default-repo
# Override only for GitHub Enterprise
# GITHUB_API_URL=https://api.github.com
